<%= form_with(model: plan) do |form| %>
  <% if plan.errors.any? %>
    <div style="color: red">
      <h2><%= plan.errors.count %>件のエラーが発生しました:</h2>
      <ul>
        <% plan.errors.full_messages.each do |error| %>
          <li><%= error %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, "タイトル" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :content, "スケジュールメモ" %>
    <%= form.text_area :content %>
  </div>

  <div>
    <%= form.label :start_time, "開始日" %>
    <%= form.datetime_field :start_time %>
  </div>

  <div>
    <%= form.label :end_time, "終了日" %>
    <%= form.datetime_field :end_time %>
  </div>

  <div>
    <%= form.label :all_day, "終日" %>
    <%= form.check_box :all_day %>
  </div>

  <div>
    <%= form.submit "保存する" %>
  </div>
<% end %>