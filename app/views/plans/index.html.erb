<p style="color: green"><%= notice %></p>

<h1>📅 予定一覧</h1>

<p>本日の日付：<%= Date.current.strftime("%Y/%m/%d") %></p>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>タイトル</th>
      <th>開始日</th>
      <th>終了日</th>
      <th>終日</th>
      <th>更新日時</th>
      <th>操作</th>
    </tr>
  </thead>

  <tbody>
    <% @plans.each do |plan| %>
      <tr>
        <td><%= plan.id %></td>
        <td><%= plan.title %></td>
        <td><%= plan.start_time.present? ? plan.start_time.strftime("%Y/%m/%d") : "" %></td>
        <td><%= plan.end_time.present? ? plan.end_time.strftime("%Y/%m/%d") : "" %></td>
        <td><%= plan.all_day ? "○" : "" %></td>
        <td><%= plan.updated_at.present? ? plan.updated_at.strftime("%Y/%m/%d %H:%M") : "" %></td>
        <td>
          <%= link_to '詳細', plan %>
          <%= link_to '編集', edit_plan_path(plan) %>
          <%= button_to "削除", plan, method: :delete, onclick: "return confirm('予定を削除しますか？')" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<p>予定の合計数：<%= @plans.count %></p>

<br>

<%= link_to '新規予定の追加', new_plan_path %>