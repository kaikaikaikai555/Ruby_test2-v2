<h1>📅 予定詳細</h1>

<div>
  <strong>タイトル:</strong>
  <%= @plan.title %>
</div>

<div>
  <strong>開始日:</strong>
  <%= @plan.start_time.present? ? @plan.start_time.strftime("%Y/%m/%d") : "未設定" %>
</div>

<div>
  <strong>終了日:</strong>
  <%= @plan.end_time.present? ? @plan.end_time.strftime("%Y/%m/%d") : "未設定" %>
</div>

<div>
  <strong>終日:</strong>
  <%= @plan.all_day ? "○" : "" %>
</div>

<div>
  <strong>スケジュールメモ:</strong>
  <%= simple_format(@plan.content) %>
</div>

<hr>

<%= link_to '編集', edit_plan_path(@plan) %> |
<%= link_to '一覧に戻る', plans_path %>